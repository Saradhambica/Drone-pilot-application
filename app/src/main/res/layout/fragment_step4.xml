<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/step4_title"
                android:textColor="#003D6B"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginBottom="24dp" />

            <!-- Tank Capacity -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tank_capacity_label"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_tank_capacity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/steps_background"
                android:padding="12dp"
                android:textColor="#000000"
                android:textColorHint="#808080"
                android:inputType="numberDecimal"
                android:layout_marginBottom="24dp" />

            <!-- Nozzle Mounting -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nozzle_mounting_label"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_nozzle_mounting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/steps_background"
                android:padding="12dp"
                android:textColor="#000000"
                android:textColorHint="#808080"
                android:inputType="text"
                android:layout_marginBottom="24dp" />

            <!-- Boom Length -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/boom_length_label"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_boom_length"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/steps_background"
                android:padding="12dp"
                android:textColor="#000000"
                android:textColorHint="#808080"
                android:inputType="numberDecimal"
                android:layout_marginBottom="24dp" />

            <!-- Number of Nozzles -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nozzle_count_label"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_nozzle_count"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/steps_background"
                android:padding="12dp"
                android:textColor="#000000"
                android:textColorHint="#808080"
                android:inputType="number"
                android:layout_marginBottom="24dp" />

            <!-- Type of Nozzle -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nozzle_type_label"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_nozzle_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/steps_background"
                android:padding="12dp"
                android:textColor="#000000"
                android:textColorHint="#808080"
                android:inputType="text"
                android:layout_marginBottom="24dp" />

            <!-- Cone Angle -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/cone_angle_label"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_cone_angle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/steps_background"
                android:padding="12dp"
                android:textColor="#000000"
                android:textColorHint="#808080"
                android:inputType="numberDecimal"
                android:layout_marginBottom="24dp" />

            <!-- Droplet Size -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/droplet_size_label"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_droplet_size"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/steps_background"
                android:padding="12dp"
                android:textColor="#000000"
                android:textColorHint="#808080"
                android:inputType="numberDecimal"
                android:layout_marginBottom="24dp" />

            <!-- Flow Rate -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/flow_rate_label"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_flow_rate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/steps_background"
                android:padding="12dp"
                android:textColor="#000000"
                android:textColorHint="#808080"
                android:inputType="numberDecimal"
                android:layout_marginBottom="24dp" />

            <!-- Operating Pressure -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/operating_pressure_label"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_operating_pressure"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/steps_background"
                android:padding="12dp"
                android:textColor="#000000"
                android:textColorHint="#808080"
                android:inputType="numberDecimal"
                android:layout_marginBottom="24dp" />

            <!-- Navigation Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end">

                <Button
                    android:id="@+id/btn_back"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/step4_back_button"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#9E9E9E"
                    android:layout_marginEnd="12dp"
                    android:paddingStart="32dp"
                    android:paddingEnd="32dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp" />

                <Button
                    android:id="@+id/btn_next"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/next_button4"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#003D6B"
                    android:paddingStart="32dp"
                    android:paddingEnd="32dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp" />

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</ScrollView>
