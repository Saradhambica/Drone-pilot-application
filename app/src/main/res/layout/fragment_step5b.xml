<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/step5b_title"
                android:textColor="#003D6B"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginBottom="24dp" />

            <!-- Target Deficiency -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/target_deficiency_label2"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_target_deficiency2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/steps_background"
                android:padding="12dp"
                android:textColor="#000000"
                android:textColorHint="#808080"
                android:inputType="text"
                android:layout_marginBottom="24dp" />

            <!-- Type of Formulation -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/formulation_type_label"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_formulation_type2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/steps_background"
                android:padding="12dp"
                android:textColor="#000000"
                android:textColorHint="#808080"
                android:inputType="text"
                android:layout_marginBottom="24dp" />

            <!-- Crop Nutrient Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/crop_nutrient_name_label2"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_crop_nutrient_name2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/steps_background"
                android:padding="12dp"
                android:textColor="#000000"
                android:textColorHint="#808080"
                android:inputType="text"
                android:layout_marginBottom="24dp" />

            <!-- Nutrient Type -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nutrient_type_label2"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_nutrient_type2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/steps_background"
                android:padding="12dp"
                android:textColor="#000000"
                android:textColorHint="#808080"
                android:inputType="text"
                android:layout_marginBottom="24dp" />

            <!-- Concentration -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/concentration_label"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_concentration2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/steps_background"
                android:padding="12dp"
                android:textColor="#000000"
                android:textColorHint="#808080"
                android:inputType="text"
                android:layout_marginBottom="24dp" />

            <!-- Dosage -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/dosage_label"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_dosage2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/steps_background"
                android:padding="12dp"
                android:textColor="#000000"
                android:textColorHint="#808080"
                android:inputType="text"
                android:layout_marginBottom="24dp" />

            <!-- Water Volume -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/water_volume_label"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_water_volume2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/steps_background"
                android:padding="12dp"
                android:textColor="#000000"
                android:textColorHint="#808080"
                android:inputType="text"
                android:layout_marginBottom="24dp" />

            <!-- Navigation Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end">

                <Button
                    android:id="@+id/btn_back"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/step5b_back_button"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#9E9E9E"
                    android:layout_marginEnd="12dp"
                    android:paddingStart="32dp"
                    android:paddingEnd="32dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp" />

                <Button
                    android:id="@+id/btn_next"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/next_button5b"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#003D6B"
                    android:paddingStart="32dp"
                    android:paddingEnd="32dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp" />

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</ScrollView>
