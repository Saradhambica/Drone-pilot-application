<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        app:cardBackgroundColor="#FFFFFF">

        <!-- Success Banner -->
        <androidx.cardview.widget.CardView
            android:id="@+id/success_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#D1F2EB"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/form_submission"
                        android:textColor="#0F5132"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- SOP Recap Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tv_summary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/sop_recap"
                    android:textColor="#212121"
                    android:textSize="16sp"
                    android:lineSpacingExtra="4dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Launch QGC Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLaunchQgc"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="@string/launch_qgc"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#198754"
            app:cornerRadius="30dp"
            android:textColor="#FFFFFF"
            app:elevation="6dp"
            app:rippleColor="#FFFFFF33"
            android:layout_marginBottom="12dp"/>


        <!-- Back to Dashboard Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_dashboard"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="@string/back_to_dashboard"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#0D6EFD"
            app:cornerRadius="30dp"
            android:textColor="#FFFFFF"
            app:elevation="6dp"
            app:rippleColor="#FFFFFF33"
            android:layout_marginBottom="12dp"/>

        <!-- Download PDF Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_download_pdf"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="@string/download_pdf"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#17A2B8"
            app:cornerRadius="30dp"
            android:textColor="#FFFFFF"
            app:elevation="6dp"
            app:rippleColor="#FFFFFF33"/>

    </LinearLayout>

</ScrollView>