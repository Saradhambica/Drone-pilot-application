<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme using MaterialComponents, NoActionBar -->
    <style name="Theme.SuperBeeApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary colors (toolbar background) -->
        <item name="colorPrimary">@color/black</item>
        <item name="colorPrimaryVariant">@color/black</item>
        <item name="colorOnPrimary">@android:color/white</item>

        <!-- Secondary colors -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorOnSecondary">@android:color/white</item>

        <!-- Status bar / navigation bar -->
        <item name="android:statusBarColor">@color/black</item>
        <item name="android:navigationBarColor">@color/black</item>

        <!-- Toolbar / ActionBar icons will be white -->
        <item name="colorControlNormal">@android:color/white</item>

        <!-- Enable MaterialComponents widgets compatibility -->
        <item name="android:windowLightStatusBar">false</item>
    </style>

</resources>
